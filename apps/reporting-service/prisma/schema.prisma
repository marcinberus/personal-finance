generator client {
  provider     = "prisma-client"
  output       = "../src/prisma/generated"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model MonthlyReportProjection {
  id           String   @id @default(uuid())
  userId       String
  year         Int
  month        Int
  incomeTotal  Decimal  @default(0) @db.Decimal(14, 2)
  expenseTotal Decimal  @default(0) @db.Decimal(14, 2)
  updatedAt    DateTime @updatedAt

  @@unique([userId, year, month])
  @@index([userId])
}

model CategorySpendProjection {
  id           String   @id @default(uuid())
  userId       String
  categoryId   String
  categoryName String
  year         Int
  month        Int
  total        Decimal  @default(0) @db.Decimal(14, 2)
  updatedAt    DateTime @updatedAt

  @@unique([userId, categoryId, year, month])
  @@index([userId, year, month])
}
