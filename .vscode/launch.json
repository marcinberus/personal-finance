{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Ledger",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start:ledger:dev"],
      "console": "integratedTerminal",
      "restart": true,
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Reporting",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start:reporting:dev"],
      "console": "integratedTerminal",
      "restart": true,
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}