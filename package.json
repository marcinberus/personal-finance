{
  "name": "personal-finance",
  "version": "0.0.1",
  "description": "",
  "author": "Marcin",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start:identity": "nest start identity-service",
    "start:identity:dev": "nest start identity-service --watch",
    "start:ledger": "nest start ledger-service",
    "start:ledger:dev": "nest start ledger-service --watch",
    "start:reporting": "nest start reporting-service",
    "start:reporting:dev": "nest start reporting-service --watch",
    "prisma:generate:identity": "prisma generate --config apps/identity-service/prisma.config.ts",
    "prisma:generate:ledger": "prisma generate --config apps/ledger-service/prisma.config.ts",
    "prisma:generate:reporting": "prisma generate --config apps/reporting-service/prisma.config.ts",
    "prisma:generate:all": "npm run prisma:generate:identity && npm run prisma:generate:ledger && npm run prisma:generate:reporting",
    "prisma:migrate:all": "prisma migrate dev --config apps/identity-service/prisma.config.ts && prisma migrate dev --config apps/ledger-service/prisma.config.ts && prisma migrate dev --config apps/reporting-service/prisma.config.ts",
    "build:all": "nest build identity-service && nest build ledger-service && nest build reporting-service",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:http:identity": "jest --config ./apps/identity-service/test/integrations/http/jest-http.json",
    "test:http:ledger": "jest --config ./apps/ledger-service/test/integrations/http/jest-http.json",
    "test:http:reporting": "jest --config ./apps/reporting-service/test/integrations/http/jest-http.json",
    "test:http:all": "npm run test:http:identity && npm run test:http:ledger && npm run test:http:reporting",
    "test:database:identity": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config ./apps/identity-service/test/integrations/database/jest-database.json --runInBand",
    "test:database:ledger": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config ./apps/ledger-service/test/integrations/database/jest-database.json --runInBand",
    "test:database:reporting": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config ./apps/reporting-service/test/integrations/database/jest-database.json --runInBand",
    "test:database:all": "npm run test:database:identity && npm run test:database:ledger && npm run test:database:reporting",
    "test:all": "npm run test && npm run test:http:all && npm run test:database:all"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.18",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^1.0.3",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": "(apps|libs)/.*\\.spec\\.ts$",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/test/integrations/"
    ],
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@app/common(|/.*)$": "<rootDir>/libs/common/src$1",
      "^@app/contracts(|/.*)$": "<rootDir>/libs/contracts/src$1",
      "^(\\.{1,2}/.*)\\.(js)$": "$1"
    },
    "collectCoverageFrom": [
      "apps/**/*.(t|j)s",
      "libs/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
