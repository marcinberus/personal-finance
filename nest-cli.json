{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "apps/identity-service",
  "sourceRoot": "apps/identity-service/src",
  "entryFile": "main",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "apps/identity-service/tsconfig.app.json"
  },
  "projects": {
    "identity-service": {
      "type": "application",
      "root": "apps/identity-service",
      "entryFile": "main",
      "sourceRoot": "apps/identity-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/identity-service/tsconfig.app.json"
      }
    },
    "ledger-service": {
      "type": "application",
      "root": "apps/ledger-service",
      "entryFile": "main",
      "sourceRoot": "apps/ledger-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ledger-service/tsconfig.app.json"
      }
    },
    "reporting-service": {
      "type": "application",
      "root": "apps/reporting-service",
      "entryFile": "main",
      "sourceRoot": "apps/reporting-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/reporting-service/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "prisma": {
      "type": "library",
      "root": "libs/prisma",
      "entryFile": "index",
      "sourceRoot": "libs/prisma/src",
      "compilerOptions": {
        "tsConfigPath": "libs/prisma/tsconfig.lib.json"
      }
    }
  }
}
